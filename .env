APP_NAME=TradingAssistant
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=change-this-to-a-random-64-char-string
LOG_LEVEL=INFO

EXECUTION_MODE=paper

DISCORD_BOT_TOKEN=dummy
DISCORD_GUILD_ID=123456789012345678
DISCORD_CHANNEL_ID=123456789012345678
DISCORD_INCLUDE_BOT_MESSAGES=false
DISCORD_HISTORICAL_BACKFILL_LIMIT=500
DISCORD_HISTORICAL_FETCH_DELAY_SECONDS=1.0

DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_assistant
DB_USER=postgres
DB_PASSWORD=dummy

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CELERY_DB=1

BINANCE_API_KEY=dummy
BINANCE_API_SECRET=dummy
BINANCE_ENVIRONMENT=testnet
BINANCE_MAX_NOTIONAL_PER_TRADE_USD=100.0
BINANCE_DEFAULT_LEVERAGE=1
BINANCE_ALLOW_SIGNAL_LEVERAGE=false

ALPACA_API_KEY=dummy
ALPACA_API_SECRET=dummy
ALPACA_ENVIRONMENT=paper
ALPACA_MAX_NOTIONAL_PER_TRADE_USD=500.0
ALPACA_FRACTIONAL_SHARES_ENABLED=false

LLM_PROVIDER=disabled
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_FALLBACK_CONFIDENCE_THRESHOLD=0.6

OPENAI_API_KEY=dummy
ANTHROPIC_API_KEY=dummy

SCORING_AUTO_EXECUTE_THRESHOLD=80
SCORING_MANUAL_REVIEW_THRESHOLD=60

RISK_DAILY_LOSS_LIMIT_USD=200.0
RISK_MAX_OPEN_POSITIONS=5
RISK_MAX_CRYPTO_EXPOSURE_USD=300.0
RISK_MAX_STOCK_EXPOSURE_USD=1500.0
RISK_CONSECUTIVE_LOSS_COOLDOWN_MINUTES=60
RISK_CONSECUTIVE_LOSSES_BEFORE_COOLDOWN=3
RISK_KILL_SWITCH_ACTIVE=false
RISK_MANUAL_PAUSE_ACTIVE=false
RISK_REQUIRE_STOP_LOSS=true
RISK_MAX_SPREAD_PCT=0.5

NOTIFY_TELEGRAM_ENABLED=false
